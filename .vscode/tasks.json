{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Build CView_v2 (Debug)",
      "type": "shell",
      "command": "xcodebuild",
      "args": [
        "-scheme", "CView_v2",
        "-configuration", "Debug",
        "-derivedDataPath", "Build",
        "build"
      ],
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      },
      "problemMatcher": []
    },
    {
      "label": "Build and Launch CView_v2",
      "dependsOn": ["Build CView_v2 (Debug)"],
      "dependsOrder": "sequence",
      "type": "shell",
      "command": "open",
      "args": [
        "${workspaceFolder}/Build/Build/Products/Debug/CView_v2.app"
      ],
      "presentation": {
        "reveal": "silent",
        "panel": "shared"
      },
      "problemMatcher": [],
      "isBackground": true
    },
    {
      "label": "Server: Status",
      "type": "shell",
      "command": "${workspaceFolder}/server-dev/server.sh",
      "args": ["status"],
      "problemMatcher": [],
      "presentation": { "reveal": "always", "panel": "dedicated" }
    },
    {
      "label": "Server: Pull Sources",
      "type": "shell",
      "command": "${workspaceFolder}/server-dev/server.sh",
      "args": ["pull"],
      "problemMatcher": [],
      "presentation": { "reveal": "always", "panel": "dedicated" }
    },
    {
      "label": "Server: Push Sources",
      "type": "shell",
      "command": "${workspaceFolder}/server-dev/server.sh",
      "args": ["push"],
      "problemMatcher": [],
      "presentation": { "reveal": "always", "panel": "dedicated" }
    },
    {
      "label": "Server: Deploy Collector",
      "type": "shell",
      "command": "${workspaceFolder}/server-dev/server.sh",
      "args": ["deploy", "collector"],
      "problemMatcher": [],
      "presentation": { "reveal": "always", "panel": "dedicated" }
    },
    {
      "label": "Server: Deploy Stats Web",
      "type": "shell",
      "command": "${workspaceFolder}/server-dev/server.sh",
      "args": ["deploy", "statsweb"],
      "problemMatcher": [],
      "presentation": { "reveal": "always", "panel": "dedicated" }
    },
    {
      "label": "Server: Logs (Metrics)",
      "type": "shell",
      "command": "${workspaceFolder}/server-dev/server.sh",
      "args": ["logs", "chzzk-metrics", "100"],
      "problemMatcher": [],
      "isBackground": true,
      "presentation": { "reveal": "always", "panel": "dedicated" }
    },
    {
      "label": "Server: Logs (Stats Web)",
      "type": "shell",
      "command": "${workspaceFolder}/server-dev/server.sh",
      "args": ["logs", "cview-stats-web", "100"],
      "problemMatcher": [],
      "isBackground": true,
      "presentation": { "reveal": "always", "panel": "dedicated" }
    },
    {
      "label": "Server: SSH Shell",
      "type": "shell",
      "command": "${workspaceFolder}/server-dev/server.sh",
      "args": ["ssh"],
      "problemMatcher": [],
      "presentation": { "reveal": "always", "panel": "dedicated", "focus": true }
    },
    {
      "label": "Swift Remote: Sync → Server",
      "type": "shell",
      "command": "${workspaceFolder}/server-dev/swift-remote.sh",
      "args": ["sync"],
      "problemMatcher": [],
      "presentation": { "reveal": "always", "panel": "dedicated" }
    },
    {
      "label": "Swift Remote: Pull ← Server",
      "type": "shell",
      "command": "${workspaceFolder}/server-dev/swift-remote.sh",
      "args": ["pull"],
      "problemMatcher": [],
      "presentation": { "reveal": "always", "panel": "dedicated" }
    },
    {
      "label": "Swift Remote: Diff",
      "type": "shell",
      "command": "${workspaceFolder}/server-dev/swift-remote.sh",
      "args": ["diff"],
      "problemMatcher": [],
      "presentation": { "reveal": "always", "panel": "dedicated" }
    },
    {
      "label": "Swift Remote: Code Stats",
      "type": "shell",
      "command": "${workspaceFolder}/server-dev/swift-remote.sh",
      "args": ["stats"],
      "problemMatcher": [],
      "presentation": { "reveal": "always", "panel": "dedicated" }
    },
    {
      "label": "Swift Remote: REPL",
      "type": "shell",
      "command": "${workspaceFolder}/server-dev/swift-remote.sh",
      "args": ["repl"],
      "problemMatcher": [],
      "presentation": { "reveal": "always", "panel": "dedicated", "focus": true }
    },
    {
      "label": "Swift Remote: Version Info",
      "type": "shell",
      "command": "${workspaceFolder}/server-dev/swift-remote.sh",
      "args": ["version"],
      "problemMatcher": [],
      "presentation": { "reveal": "always", "panel": "dedicated" }
    }
  ]
}
